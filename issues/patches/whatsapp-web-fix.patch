 def split_message(message, max_length=1000):
     return [message[i:i + max_length] for i in range(0, len(message), max_length)]
 
+
+# A bare WhatsApp timestamp line, e.g. "12:59 PM" or "11:42 AM".
+_WA_TIMESTAMP_RE = re.compile(r"^\d{1,2}:\d{2}\s*(AM|PM)$", re.IGNORECASE)
+# A voice-note duration line, e.g. "0:19".
+_WA_DURATION_RE = re.compile(r"^\d{1,2}:\d{2}$")
+# Noise labels WhatsApp / business bots render inside a message row. Matched as
+# line prefixes because a suggestion label and a voice-note duration can render
+# mashed onto a single line (e.g. "Related questions 0:19").
+_WA_NOISE_PREFIXES = ("you", "related questions", "forwarded")
+
+
+def clean_whatsapp_response(text: str, prompt: str = "") -> str:
+    """Strip WhatsApp row-chrome from a scraped message.
+
+    A scraped ``div[role=row]`` innerText can include an avatar label ("You"),
+    the echoed prompt (for quoted/reply bubbles), bare timestamps, voice-note
+    durations and suggestion labels. Keep only the substantive answer lines.
+    """
+    prompt_norm = (prompt or "").strip().lower()
+    kept = []
+    for raw in (text or "").splitlines():
+        line = raw.strip()
+        if not line:
+            continue
+        low = line.lower()
+        if any(low == p or low.startswith(p + " ") for p in _WA_NOISE_PREFIXES):
+            continue
+        if prompt_norm and low == prompt_norm:
+            continue
+        if _WA_TIMESTAMP_RE.match(line) or _WA_DURATION_RE.match(line):
+            continue
+        kept.append(line)
+    return "\n".join(kept).strip()
+
