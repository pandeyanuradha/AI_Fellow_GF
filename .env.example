# =============================================================================
# Copy this to `.env` and fill in your keys. `.env` is gitignored.
# =============================================================================

# --- LLM provider -------------------------------------------------------------
# Which OpenAI-compatible backend serves the endpoint + the factuality judge.
#   ollama  (default)  local Ollama, ZERO API keys, fully reproducible
#   groq               Groq free tier  (set GROQ_API_KEY below)
#   hf                 Hugging Face Inference router  (set HF_TOKEN below)
# The reproducible results run uses `ollama`; the deployed HF Space uses `hf`.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1

# Target model — what the endpoint uses to answer user questions.
TARGET_MODEL=qwen2.5:7b

# Judge model — what the evaluator uses to score factuality.
# MUST differ from TARGET_MODEL (kills bug #4 self-bias). With Ollama this
# is a second local model; pull it once: `ollama pull llama3.2:3b`.
JUDGE_MODEL=llama3.2:3b

# --- Groq (only if LLM_PROVIDER=groq) -----------------------------------------
# Sign up (free, no card): https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Endpoint configuration ---
ENDPOINT_HOST=0.0.0.0
ENDPOINT_PORT=8000

# --- RAG configuration ---
RAG_TOP_K=4
RAG_CORPUS_DIR=endpoint/corpus
RAG_INDEX_DIR=endpoint/index
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Bias detector (fixes bug #5) ---
# Multilingual NLI model with proper zero-shot ["biased", "not biased"] candidates.
# Works for English + Hindi + 15 other Indic + global languages.
BIAS_MODEL=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli

# --- Optional: Hugging Face (LLM_PROVIDER=hf and/or `spaces` deploy) ----------
# Get a token: https://huggingface.co/settings/tokens
# read-scope is enough for HF Inference; write-scope needed to push a Space.
HF_TOKEN=
HF_USERNAME=
HF_SPACE_NAME=maternal-health-qa
# HF_BASE_URL=https://router.huggingface.co/v1
